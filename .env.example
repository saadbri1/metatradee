# ============================================================================
# MetaTradee — Environment Variables
# Copy to `.env.local` for local development. NEVER commit real secrets.
# Public (NEXT_PUBLIC_*) vars are exposed to the browser — put only non-secrets there.
# ============================================================================

# --- App -------------------------------------------------------------------
# Public base URL of the app (used for redirects, metadata, OG).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Deployment environment: development | preview | staging | production
NEXT_PUBLIC_APP_ENV="development"

# --- Supabase (auth + database + storage) ----------------------------------
# Project URL, e.g. https://xxxx.supabase.co  (public, safe for browser)
NEXT_PUBLIC_SUPABASE_URL=""
# Anon/public key (public, RLS-protected — safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key (SERVER ONLY — bypasses RLS. NEVER expose to the client.)
SUPABASE_SERVICE_ROLE_KEY=""

# --- AI providers (server only — via Model Router, see Phase 7) -------------
# Populate only the providers you enable. Feature code never reads these directly.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
OPENROUTER_API_KEY=""

# --- Payments (server only, Phase 8) ---------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""

# --- Email (server only) ----------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="MetaTradee <noreply@metatradee.com>"

# --- Market data (server only, Phase 3) ------------------------------------
POLYGON_API_KEY=""
DATABENTO_API_KEY=""

# --- Observability (optional) ----------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
